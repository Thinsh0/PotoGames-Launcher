<html lang="en" xmlns="http://www.w3.org/1999/xhtml">

<head>
    <meta charset="utf-8" http-equiv="Content-Security-Policy"
        content="script-src 'self' 'sha256-In6B8teKZQll5heMl9bS7CESTbGvuAt3VVV86BUQBDk=' 'sha256-4IZ3b7bBwcnAKzoTitxuDtvPc3sDRHXGd70Y6kjOFYg='" />
    <title>
        <%= lang('app.title') %>
    </title>
    <script src="./assets/js/scripts/uicore.js"></script>
    <script src="./assets/js/scripts/uibinder.js"></script>
    <link type="text/css" rel="stylesheet" href="./assets/css/launcher.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
    <style>
        html, body {
            background: transparent !important;
            overflow: hidden !important;
            width: 100vw;
            height: 100vh;
            margin: 0;
            padding: 0;
        }

        #ui_container {
            width: calc(100% - 2px);
            height: calc(100% - 2px);
            margin: 1px;
            background: rgba(32, 32, 32, 0.75) !important;
            border-radius: 16px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            position: relative;
            /* Force strict Webkit clipping for rounded corners on positioned children */
            -webkit-mask-image: -webkit-radial-gradient(white, black);
            mask-image: radial-gradient(white, black);
            isolation: isolate;
        }

        #main {
            display: none;
            flex: 1;
            background: transparent;
            width: 100%;
            position: relative;
            z-index: 10;
            overflow: hidden;
        }

        #main[overlay] {
            filter: blur(8px) brightness(0.8);
        }

        #hero_avatar_img {
            mix-blend-mode: screen;
        }
    </style>
</head>

<body bkid="<%=bkid%>">
    <div id="ui_container">
        <%- include('frame') %>
        <div id="main">
            <%- include('welcome') %>
            <%- include('login') %>
            <%- include('waiting') %>
            <%- include('loginOptions') %>
            <%- include('settings') %>
            <%- include('landing') %>
        </div>
        <%- include('overlay') %>
        <div id="loadingContainer">
            <div id="loadingContent">
                <div id="loadSpinnerContainer">
                    <img id="loadCenterImage" src="assets/images/logo.png">
                </div>
            </div>
        </div>
    </div>
</body>

</html>