<html lang="en" xmlns="http://www.w3.org/1999/xhtml">

<head>
    <meta charset="utf-8" http-equiv="Content-Security-Policy"
        content="script-src 'self' 'sha256-In6B8teKZQll5heMl9bS7CESTbGvuAt3VVV86BUQBDk='" />
    <title>
        <%= lang('app.title') %>
    </title>
    <script src="./assets/js/scripts/uicore.js"></script>
    <script src="./assets/js/scripts/uibinder.js"></script>
    <link type="text/css" rel="stylesheet" href="./assets/css/launcher.css">
    <style>
        body {
            background: rgba(32, 32, 32, 0.75) !important;
            -webkit-user-select: none;
            overflow: hidden !important;
            border-radius: 16px !important;
            border: 1px solid rgba(255, 255, 255, 0.12);
        }

        #main {
            display: none;
            height: calc(100% - 22px);
            background: transparent;
            width: 100%;
            position: absolute;
            z-index: 10;
            overflow: hidden;
            border-radius: 16px;
        }

        #main[overlay] {
            filter: blur(8px) brightness(0.8);
        }
    </style>
</head>

<body bkid="<%=bkid%>">
    <%- include('frame') %>
        <div id="main">
            <%- include('welcome') %>
                <%- include('login') %>
                    <%- include('waiting') %>
                        <%- include('loginOptions') %>
                            <%- include('settings') %>
                                <%- include('landing') %>
        </div>
        <%- include('overlay') %>
            <div id="loadingContainer">
                <div id="loadingContent">
                    <div id="loadSpinnerContainer">
                        <img id="loadCenterImage" src="assets/images/LoadingSeal.png">
                        <img id="loadSpinnerImage" class="rotating" src="assets/images/LoadingText.png">
                    </div>
                </div>
            </div>
</body>

</html>